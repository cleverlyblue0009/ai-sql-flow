# API Configuration
VITE_API_URL=http://localhost:8000

# Database Configuration (Optional - for full backend functionality)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dataflow_ai
ASYNC_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/dataflow_ai
REDIS_URL=redis://localhost:6379/0

# Security Configuration
SECRET_KEY=dev-secret-key-change-in-production-min-32-chars-for-security
ENCRYPTION_KEY=dev-encryption-key-32-chars-long!
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Application Configuration
DEBUG=true
LOG_LEVEL=INFO
MAX_FILE_SIZE_MB=500
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:8000"]

# Development Mode Settings
PYTHONPATH=/workspace
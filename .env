# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_data_platform
ASYNC_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_data_platform
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OAuth2 (Optional - leave empty for now)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# AWS/MinIO (Optional - leave empty for local storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=ai-data-platform-storage

# MinIO (Alternative to AWS S3)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Application Settings
DEBUG=True
LOG_LEVEL=INFO
MAX_FILE_SIZE_MB=100
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=./storage

# Email Configuration (Optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
FROM_EMAIL=noreply@aidataplatform.com

# Hugging Face (Optional - for AI features)
HUGGINGFACE_API_KEY=

# CORS
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:5173", "http://localhost:8000"]